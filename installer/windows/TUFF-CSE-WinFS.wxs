<?xml version="1.0" encoding="utf-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Package Name="TUFF-CSE-WinFS Public Installer" Language="1033" Version="1.0.0.0" Manufacturer="elementary-particles-Man" UpgradeCode="00000000-0000-0000-0000-000000000000">
    <MajorUpgrade DowngradeErrorMessage="A newer version of TUFF-CSE-WinFS is already installed." />
    <MediaTemplate />
    <Feature Id="MainFeature" Title="TUFF-CSE-WinFS Public Package" Level="1">
      <ComponentGroupRef Id="InstallerBinaries" />
      <ComponentGroupRef Id="InstallerDocs" />
    </Feature>
  </Package>

  <Fragment>
    <Directory Id="TARGETDIR" Name="SourceDir">
      <Directory Id="ProgramFiles64Folder">
        <Directory Id="INSTALLFOLDER" Name="TUFF-CSE-WinFS" />
      </Directory>
    </Directory>
  </Fragment>

  <Fragment>
    <ComponentGroup Id="InstallerBinaries">
      <Component Id="SetupExe" Directory="INSTALLFOLDER" Guid="11111111-1111-1111-1111-111111111111">
        <File Source="TuffCseWinFsSetup.exe" KeyPath="yes" />
      </Component>
      <Component Id="CtlExe" Directory="INSTALLFOLDER" Guid="22222222-2222-2222-2222-222222222222">
        <File Source="tuff-cse-winfsctl.exe" KeyPath="yes" />
      </Component>
    </ComponentGroup>
  </Fragment>

  <Fragment>
    <ComponentGroup Id="InstallerDocs">
      <Component Id="ReadmeFirst" Directory="INSTALLFOLDER" Guid="33333333-3333-3333-3333-333333333333">
        <File Source="README-FIRST.txt" KeyPath="yes" />
      </Component>
      <Component Id="LicenseRtf" Directory="INSTALLFOLDER" Guid="44444444-4444-4444-4444-444444444444">
        <File Source="LICENSE.rtf" KeyPath="yes" />
      </Component>
    </ComponentGroup>
  </Fragment>
</Wix>

