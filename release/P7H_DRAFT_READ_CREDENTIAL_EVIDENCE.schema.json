{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/elementary-particles-Man/TUFF-CSE-WinFS/releases/P7H_DRAFT_READ_CREDENTIAL_EVIDENCE.schema.json",
  "title": "TUFF-CSE-WinFS Draft Read Credential Evidence",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "repository",
    "credential_class",
    "credential_prefix_verified",
    "repository_access_verified",
    "contents_read_verified",
    "actions_read_verified",
    "rc1_draft_read_verified",
    "rc2_draft_read_verified",
    "release_assets_read_verified",
    "source_artifact_read_verified",
    "byte_identity_verified",
    "rc1_metadata_sha256",
    "rc2_metadata_sha256",
    "mutation_attempted",
    "generated_at_utc"
  ],
  "properties": {
    "repository": {
      "type": "string",
      "minLength": 1
    },
    "credential_class": {
      "const": "fine-grained-personal-access-token"
    },
    "credential_prefix_verified": {
      "const": true
    },
    "repository_access_verified": {
      "const": true
    },
    "contents_read_verified": {
      "const": true
    },
    "actions_read_verified": {
      "const": true
    },
    "rc1_draft_read_verified": {
      "const": true
    },
    "rc2_draft_read_verified": {
      "const": true
    },
    "release_assets_read_verified": {
      "const": true
    },
    "source_artifact_read_verified": {
      "const": true
    },
    "byte_identity_verified": {
      "const": true
    },
    "rc1_metadata_sha256": {
      "$ref": "#/$defs/sha256"
    },
    "rc2_metadata_sha256": {
      "$ref": "#/$defs/sha256"
    },
    "mutation_attempted": {
      "const": false
    },
    "generated_at_utc": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    }
  }
}
